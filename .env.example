# ============================================================
# Variáveis de ambiente — Produtividade App
# ============================================================
# Copie este arquivo para .env e preencha com suas chaves reais.
# NUNCA suba o arquivo .env para o repositório (já está no .gitignore).
#
# No Vercel: adicione as variáveis em Settings > Environment Variables.
# ============================================================

# ----- Groq AI (obrigatório) --------------------------------
# Crie sua chave em: https://console.groq.com/keys
VITE_GROQ_API_KEY=YOUR_GROQ_API_KEY

# ----- Groq — chaves específicas por contexto (opcional) ----
# Se não definidas, o app usa VITE_GROQ_API_KEY como fallback.
# VITE_GROQ_API_KEY_CHAT=YOUR_GROQ_API_KEY_CHAT
# VITE_GROQ_API_KEY_DIET=YOUR_GROQ_API_KEY_DIET
# VITE_GROQ_API_KEY_REGION=YOUR_GROQ_API_KEY_REGION

# ----- Supabase (desabilitado — será reativado futuramente) --
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
